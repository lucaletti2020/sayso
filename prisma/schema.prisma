generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required tables ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App tables ───────────────────────────────────────────────────────────────

model User {
  id               String          @id @default(cuid())
  name             String?
  email            String?         @unique
  emailVerified    DateTime?
  image            String?
  linkedinUrl      String?
  jobTitle         String?
  company          String?
  companySize      String?
  industry         String?
  englishLevel     String?
  cefrLevel        String?
  nativeLanguage   String?
  responsibilities String?         @db.Text
  onboardingDone   Boolean         @default(false)
  reengageEmailSentAt DateTime?
  createdAt        DateTime        @default(now())
  accounts         Account[]
  sessions         Session[]
  scenarioGroups   ScenarioGroup[]
  attempts         UserAttempt[]
}

model ScenarioGroup {
  id         String     @id @default(cuid())
  userId     String
  title      String
  orderIndex Int
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarios  Scenario[]

  @@index([userId])
}

model Scenario {
  id          String              @id @default(cuid())
  groupId     String
  userId      String
  title            String
  description      String              @db.Text
  status           ScenarioStatus      @default(UNLOCKED)
  simulationPrompt String?             @db.Text
  objectives       Json?
  group       ScenarioGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sentences   PracticeSentence[]
  attempts    UserAttempt[]

  @@index([userId])
  @@index([groupId])
}

enum ScenarioStatus {
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

model PracticeSentence {
  id           String   @id @default(cuid())
  scenarioId   String
  text         String
  translation  String?
  grammarPoint String?
  audioUrl     String?
  orderIndex   Int
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

model UserAttempt {
  id           String      @id @default(cuid())
  userId       String
  scenarioId   String
  type         AttemptType
  transcript   String?     @db.Text
  feedbackJson Json?
  score        Float?
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario     Scenario    @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scenarioId])
}

enum AttemptType {
  SIMULATION
  PRONUNCIATION
}

// ─── Curriculum library (seeded from the multi-role curriculum CSV) ───────────

model CurriculumUnit {
  level      String
  unitNumber Int
  grammar    String               @db.Text
  vocabulary String               @db.Text
  functions  String               @db.Text
  scenarios  CurriculumScenario[]

  // Unit numbers restart per level, so the identity is (level, unitNumber).
  @@id([level, unitNumber])
}

model CurriculumScenario {
  id            String         @id @default(cuid())
  level         String
  unitNumber    Int
  industry      String
  jobTitle      String
  scenarioTitle String         @db.Text
  unit          CurriculumUnit @relation(fields: [level, unitNumber], references: [level, unitNumber], onDelete: Cascade)

  @@unique([level, unitNumber, industry, jobTitle])
  @@index([industry, jobTitle])
}
